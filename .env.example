# ====================================================================================
#  clinic-api — environment (copy to .env and fill in). NEVER commit the real .env.
#  Every variable the code reads is listed. In development the app boots with the
#  defaults below (mock drivers + auto-generated secrets); production needs real values.
# ====================================================================================

# ---- Core ----
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000          # this backend's own base URL (used in signed file links)
CLIENT_URL=http://localhost:5173            # the clinic-web app (CORS origin + public links)
# PUBLIC_WEB_URL=http://localhost:5173       # optional; defaults to CLIENT_URL (booking/QR links)

# ---- Dev-only auth bypass (NEVER enable in a deployed/shared env) ----
# true → identity comes from x-dev-* request headers instead of a Clerk session, so you can
# run the API locally without Clerk keys. FAIL-CLOSED: refuses to boot unless NODE_ENV is
# development/test. Set to false and provide Clerk keys to use real auth.
DEV_AUTH=true

# ---- Database (Phase 0) ----
MONGODB_URI=mongodb://localhost:27017/clinic-os   # docker-compose provides this locally (or an Atlas mongodb+srv URI)
# Optional: point Node's DNS resolver at public servers. Needed on some Windows/managed
# networks where mongodb+srv:// (Atlas) SRV lookups fail with ECONNREFUSED though the OS
# resolves fine. Leave blank for local Mongo / when SRV works.
# DNS_SERVERS=8.8.8.8,1.1.1.1

# ---- Redis / BullMQ — reminder scheduler (Phase 1, optional) ----
# Without it, due reminders are still persisted and processed by a poller.
REDIS_URL=redis://localhost:6379

# ---- Clerk auth (Phase 0) — https://dashboard.clerk.com → API Keys ----
# Required only when DEV_AUTH=false.
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx              # Clerk org/user webhook sync (optional; unused until wired)

# ---- Email + OTP via Nodemailer (Phase 1) ----
# Without SMTP creds, a JSON transport "sends" to the server log (enough to read OTPs in dev).
# Free SMTP tiers: Brevo (smtp-relay.brevo.com), Resend, or Gmail app-password for testing.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Clinic OS <no-reply@clinic-os.local>"
OTP_TTL_MINUTES=10
OTP_HASH_SECRET=                            # 32+ random bytes. Optional in dev (auto), REQUIRED in prod

# ---- Patient portal sessions (email-OTP) ----
PATIENT_JWT_SECRET=                         # 32+ random bytes. Optional in dev (auto), REQUIRED in prod
PATIENT_SESSION_TTL_HOURS=24

# ---- File storage: LOCAL DISK by default (Phase 2, HARD RULE 3: files are private) ----
STORAGE_DRIVER=local                        # local | s3 | cloudinary  (s3/cloudinary are future stubs)
LOCAL_STORAGE_DIR=./storage                 # private folder OUTSIDE the web root — gitignored, never served
FILE_URL_SECRET=                            # signs short-lived file links. Optional in dev (auto), REQUIRED in prod
FILE_URL_TTL_SECONDS=120                    # signed file link lifetime
MAX_UPLOAD_BYTES=15728640                   # 15 MB upload cap
# --- S3 (only when STORAGE_DRIVER=s3; leave blank for local) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# S3_BUCKET_NAME=                           # bucket MUST be private (no public ACL)
# --- Cloudinary (only when STORAGE_DRIVER=cloudinary; future stub) ---
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ---- Payments: Razorpay (Phase 3) ----
PAYMENTS_DRIVER=mock                        # mock (dev, local gateway w/ real HMAC) | razorpay (prod)
PAYMENTS_CURRENCY=INR
# Required only when PAYMENTS_DRIVER=razorpay — use TEST-mode keys locally:
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your_test_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret # from the Razorpay webhook you point at /api/payments/webhook

# ---- Notifications / WhatsApp (Phase 1/4) ----
NOTIFY_DEFAULT_CHANNEL=email                # default outbound channel; email is always the fallback
WHATSAPP_DRIVER=none                        # none (email only) | baileys (unofficial, free, local)
BAILEYS_SESSION_DIR=./baileys_auth          # Baileys device session — gitignored (scan the QR once)
# (The official WhatsApp Business Cloud API is intentionally NOT supported.)

# ---- AI assistant (Phase 4, HARD RULE 2: never diagnoses) ----
AI_DRIVER=mock                              # mock (dev, safe deterministic) | groq | anthropic
# Required only when AI_DRIVER=groq (OpenAI-compatible Chat Completions):
GROQ_API_KEY=gsk_xxx
# GROQ_BASE_URL=https://api.groq.com/openai/v1   # override only if needed
# Required only when AI_DRIVER=anthropic:
ANTHROPIC_API_KEY=sk-ant-xxx
AI_MODEL=openai/gpt-oss-120b                # groq default; use claude-sonnet-5 for anthropic

# ---- Public clinic websites (§5.19 / 8.6) — platform-hosted only, NO custom domains ----
PLATFORM_DOMAIN=localhost                   # prod e.g. yourdomain.com → sites at <slug>.yourdomain.com
PUBLIC_SITE_BASE_URL=http://localhost:5173  # where public sites live; local dev uses the /c/<slug> path form

# ---- Super-admin platform analytics (Phase 3) ----
# Comma-separated Clerk user ids allowed the ONE cross-clinic (aggregate-only) read.
SUPER_ADMIN_IDS=
