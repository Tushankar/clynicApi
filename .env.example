# ---- clinic-api environment ----
# Copy to .env and fill in. NEVER commit the real .env.

# Server
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed CORS origins (the clinic-web dev server, etc.)
CORS_ORIGINS=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb+srv://stutikyptronix_db_user:KVebwoZ6qZbBdX7d@cluster0.6bhj96m.mongodb.net/clinic_saas

# Clerk (https://dashboard.clerk.com -> API Keys)
# Backend uses the secret key + publishable key to verify sessions.
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx

# ---- Phase 1 ----
# Public booking page base URL (shareable links / QR).
PUBLIC_WEB_URL=http://localhost:5173
# Reminders: REDIS_URL enables the BullMQ worker; without it a poller processes
# due reminders. Optional in dev (reminders are still persisted + processable).
# REDIS_URL=redis://127.0.0.1:6379
# Email (Nodemailer). Without SMTP creds, a JSON transport "sends" to the log —
# enough to verify reminders + OTP in dev. Set these for real delivery.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
MAIL_FROM=Clinic OS <no-reply@clinic-os.local>
# Email OTP: set OTP_HASH_SECRET in production (32+ random bytes) so a leaked
# otpChallenges row can't be brute-forced; dev uses a per-boot random key.
# OTP_HASH_SECRET=
OTP_TTL_MINUTES=10

# ---- Dev-only auth bypass (NEVER enable in any deployed/shared environment) ----
# When DEV_AUTH=true AND NODE_ENV is development or test, the auth middleware accepts
# identity from request headers instead of a Clerk session, so you can exercise the
# API locally without Clerk keys:
#   x-dev-clinic-id: org_dev_clinic_a     (becomes req.ctx.clinicId)
#   x-dev-role:      owner|doctor|receptionist
#   x-dev-user-id:   user_dev_123
# FAIL CLOSED: the app refuses to boot if DEV_AUTH=true while NODE_ENV is anything
# other than 'development' or 'test' (e.g. production, staging, prod).
DEV_AUTH=false
